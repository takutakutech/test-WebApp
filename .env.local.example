# ============================================================
# Clerk (https://dashboard.clerk.com でキーを取得)
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk リダイレクト設定
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================================
# Stripe (https://dashboard.stripe.com でキーを取得)
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Webhook シークレット (stripe listen コマンド実行後に表示される)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe 商品の価格ID (Stripe ダッシュボードで作成)
STRIPE_PRICE_ID=price_xxxxx

# ============================================================
# Database (https://neon.tech でプロジェクト作成後に取得)
# ============================================================
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ============================================================
# App URL (本番環境では実際のURLに変更)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
